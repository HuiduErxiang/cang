  "study_details": {
    "design": "Multicenter, randomized, double-blind, placebo-controlled, 18-month phase 3 trial",
    "centers": "277 medical research centers/hospitals in 8 countries",
    "enrollment_period": "June 2020 to November 2021",
    "last_patient_visit": "April 2023",
    "sample_size": {
      "total": 1736,
      "donanemab": 860,
      "placebo": 876,
      "low_medium_tau": 1182,
      "high_tau": 552
    },
    "inclusion_criteria": [
      "Age 60-85 years",
      "Early symptomatic Alzheimer disease (mild cognitive impairment/mild dementia)",
      "Amyloid pathology (≥37 Centiloids) on PET",
      "Tau pathology on 18F-flortaucipir PET",
      "MMSE score 20-28"
    ],
    "exclusion_criteria": [
      "Presence of amyloid-related imaging abnormalities of edema/effusion",
      ">4 cerebral microhemorrhages",
      ">1 area of superficial siderosis",
      "Any intracerebral hemorrhage >1 cm",
      "Severe white matter disease on MRI"
    ]
  },
  
  "intervention": {
    "donanemab_dose": "700 mg for first 3 doses, 1400 mg thereafter",
    "administration": "Intravenous every 4 weeks for up to 72 weeks",
    "treatment_completion_criteria": "Amyloid plaque level <11 Centiloids on single PET scan or 11-<25 Centiloids on 2 consecutive scans"
  },
  
  "primary_outcome": {
    "measure": "Change in integrated Alzheimer Disease Rating Scale (iADRS) score from baseline to 76 weeks",
