    "article_type": "expert_consensus",
    "disease_area": ["non_small_cell_lung_cancer"],
    "gene_targets": ["EGFR ex20ins"],
    "consensus_statements": [
      {
        "consensus_id": "CONSENSUS-001",
        "statement": "EGFR ex20ins是第三大EGFR突变，在我国占EGFR突变NSCLC患者的2%-5%，异质性强，常规EGFR-TKIs治疗无效，患者预后差",
        "evidence_level": "epidemiological_data",
        "clinical_action": "临床需引起重视"
      },
      {
        "consensus_id": "CONSENSUS-002",
        "statement": "EGFR ex20ins可采用PCR和NGS进行检测；检测样本优选组织样本；组织样本不可及时，可选择液体样本；PCR检测结果为全阴性的患者，可使用NGS进行复测",
        "evidence_level": "expert_opinion",
        "clinical_action": "推荐NGS为优选检测手段"
      },
      {
        "consensus_id": "CONSENSUS-003",
        "statement": "国内尚无一线治疗局部晚期或转移性EGFR ex20ins NSCLC的靶向药物获批，建议参考无驱动基因晚期NSCLC的一线治疗",
        "evidence_level": "regulatory_status",
        "clinical_action": "含铂化疗为主"
      },
      {
        "consensus_id": "CONSENSUS-004",
        "statement": "EGFR ex20ins局部晚期或转移性NSCLC患者二线治疗，优先推荐靶向治疗药物舒沃替尼",
        "evidence_level": "phase_ii_data",
        "clinical_action": "I级推荐"
      },
      {
        "consensus_id": "CONSENSUS-005",
        "statement": "目前EGFR ex20ins NSCLC新型靶向药物研发主要是小分子EGFR-TKIs类药物和大分子抗体类药物",
        "evidence_level": "drug_development_status",
        "clinical_action": "关注临床试验"
      },
      {
        "consensus_id": "CONSENSUS-006",
        "statement": "目前有多个针对EGFR ex20ins治疗的靶向药物正在临床研究中，可建议患者积极参与临床研究",
        "evidence_level": "clinical_trial_availability",
        "clinical_action": "推荐患者参与临床试验"
      }
    ],
